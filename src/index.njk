<script>
(() => {
  const carousel = document.querySelector("[data-article-carousel]");
  if (!carousel) return;

  const track = carousel.querySelector(".article-track");
  const cards = Array.from(carousel.querySelectorAll(".article-card"));
  const prev = carousel.querySelector("[data-prev]");
  const next = carousel.querySelector("[data-next]");
  const desktopQuery = window.matchMedia("(min-width: 768px)");
  const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
  const autoplayDelay = 5200;
  let index = 0;
  let autoplayTimer = null;
  let isHoverPaused = false;
  let isFocusPaused = false;

  function update() {
    const card = cards[index];
    if (!card || !track) return;
    const pageY = window.scrollY;
    const nextLeft = card.getBoundingClientRect().left - track.getBoundingClientRect().left + track.scrollLeft;
    track.scrollTo({ left: nextLeft, behavior: "smooth" });
    if (window.scrollY !== pageY) {
      window.scrollTo({ top: pageY, left: window.scrollX, behavior: "auto" });
    }
  }

  function canAutoplay() {
    return cards.length > 3 && desktopQuery.matches && !reducedMotionQuery.matches;
  }

  function stopAutoplay() {
    if (!autoplayTimer) return;
    window.clearInterval(autoplayTimer);
    autoplayTimer = null;
  }

  function startAutoplay() {
    stopAutoplay();
    if (isHoverPaused || isFocusPaused || !canAutoplay()) return;
    autoplayTimer = window.setInterval(() => {
      index = index >= cards.length - 1 ? 0 : index + 1;
      update();
    }, autoplayDelay);
  }

  function restartAutoplay() {
    if (!canAutoplay()) return;
    startAutoplay();
  }

  prev.addEventListener("click", () => {
    index = index <= 0 ? cards.length - 1 : index - 1;
    update();
    restartAutoplay();
  });

  next.addEventListener("click", () => {
    index = index >= cards.length - 1 ? 0 : index + 1;
    update();
    restartAutoplay();
  });

  carousel.addEventListener("mouseenter", () => {
    isHoverPaused = true;
    stopAutoplay();
  });

  carousel.addEventListener("mouseleave", () => {
    isHoverPaused = false;
    startAutoplay();
  });

  carousel.addEventListener("focusin", () => {
    isFocusPaused = true;
    stopAutoplay();
  });

  carousel.addEventListener("focusout", () => {
    isFocusPaused = carousel.contains(document.activeElement);
    if (!isFocusPaused) startAutoplay();
  });

  desktopQuery.addEventListener("change", startAutoplay);
  reducedMotionQuery.addEventListener("change", startAutoplay);
  startAutoplay();
})();
</script>
