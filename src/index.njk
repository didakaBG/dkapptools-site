<script>
(() => {
  const carousel = document.querySelector("[data-shot-carousel]");
  if (!carousel) return;

  const track = carousel.querySelector(".dk-shot-article-track");
  const cards = Array.from(track.children);
  const prev = carousel.querySelector("[data-shot-prev]");
  const next = carousel.querySelector("[data-shot-next]");
  const dots = Array.from(document.querySelectorAll("[data-shot-dots] button"));

  let index = 0;

  function update() {
    const card = cards[index];
    if (!card) return;

    card.scrollIntoView({
      behavior: "smooth",
      inline: "start",
      block: "nearest"
    });

    dots.forEach((dot, dotIndex) => {
      dot.classList.toggle("active", dotIndex === index);
    });
  }

  prev.addEventListener("click", () => {
    index = index <= 0 ? cards.length - 1 : index - 1;
    update();
  });

  next.addEventListener("click", () => {
    index = index >= cards.length - 1 ? 0 : index + 1;
    update();
  });

  dots.forEach((dot, dotIndex) => {
    dot.addEventListener("click", () => {
      index = dotIndex;
      update();
    });
  });
})();
</script>
