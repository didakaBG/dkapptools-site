---
layout: base.njk
title: DK App Tools | Practical apps and digital tools
description: DK App Tools is a compact software hub for practical apps, product pages, support, privacy information, and useful articles.
permalink: /index.html
---
<section class="home-shell">
  <section class="hero-panel surface-panel">
    <div class="hero-copy">
      <p class="kicker">DK App Tools</p>
      <h1 class="hero-title">
        <span class="hero-title-dk">DK</span>
        <span class="hero-title-main">App Tools</span>
      </h1>
      <p class="hero-lead">
        Practical apps, clear product pages, useful articles, and support in one place.
      </p>
      <div class="hero-actions">
        <a class="gold-button" href="/apps/">Explore apps</a>
        <a class="plain-button" href="/articles/">Read articles</a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <img src="/assets/img/home-hero-showcase.webp" alt="">
    </div>
  </section>

  <section class="compact-panel home-apps-panel">
    <div class="section-head section-head-rich">
      <div>
        <p class="kicker">Featured app</p>
        <h2>First release: Offline FileSecure.</h2>
      </div>
      <a href="/apps/">View apps</a>
    </div>

    <div class="home-app-feature">
      <article class="app-card live home-featured-product">
        <div class="home-featured-product-copy">
          <span class="home-product-icon" aria-hidden="true">
            <img src="/assets/img/offline-filesecure-icon-clean.png" alt="">
          </span>
          <div>
            <strong>Offline FileSecure</strong>
            <p>The first app from DK App Tools helps protect private files locally on Android, with clear product and privacy information alongside it.</p>
          </div>
        </div>

        <div class="home-product-points" aria-label="Offline FileSecure highlights">
          <span>Local vault</span>
          <span>Offline-first</span>
          <span>Clear privacy policy</span>
        </div>

        <div class="home-app-actions">
          <a class="gold-button" href="/apps/offline-filesecure/">Open product page</a>
          <a class="plain-button" href="/privacy/offline-filesecure/">Privacy policy</a>
        </div>
      </article>

      <article class="home-brand-card">
        <p class="kicker">Brand home</p>
        <strong>DK App Tools</strong>
        <p>DK App Tools is the home for our apps, product pages, articles, support, and privacy information.</p>
        <div class="home-brand-links">
          <a href="/support/">Support</a>
          <a href="/privacy/">Privacy</a>
        </div>
      </article>
    </div>
  </section>

  <section class="compact-panel home-articles-panel">
    <div class="section-head section-head-rich with-link">
      <div>
        <p class="kicker">Latest articles</p>
        <h2>Practical notes for private, local-first workflows.</h2>
      </div>
      <a href="/articles/">View all articles</a>
    </div>
    <div class="article-carousel" data-article-carousel>
      <button class="carousel-button prev" type="button" data-prev aria-label="Previous articles"></button>
      <div class="article-window">
        <div class="article-track">
          {% for article in collections.publishedArticles %}
            {% if loop.index <= 6 %}
              <a class="article-card" href="{{ article.url }}">
                <img src="{{ article.data.cardImage or article.data.image }}" alt="{{ article.data.cardImageAlt or article.data.title }}" loading="lazy">
                <span class="chip">{{ article.data.category }}</span>
                <strong>{{ article.data.title }}</strong>
                <p>{{ article.data.description }}</p>
                <em>Read article</em>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <button class="carousel-button next" type="button" data-next aria-label="Next articles"></button>
    </div>
  </section>

  <section class="compact-panel home-resources-panel">
    <div class="section-head section-head-rich">
      <div>
        <p class="kicker">Resources</p>
        <h2>Everything around the apps stays easy to find.</h2>
      </div>
    </div>
    <div class="resource-grid">
      <a class="resource-card" href="/articles/">
        <span class="resource-icon" aria-hidden="true"></span>
        <strong>Articles</strong>
        <p>Guides and practical notes.</p>
        <em>Browse articles</em>
      </a>
      <a class="resource-card" href="/support/">
        <span class="resource-icon" aria-hidden="true"></span>
        <strong>Support</strong>
        <p>Help, contact, and answers.</p>
        <em>Visit support</em>
      </a>
      <a class="resource-card" href="/privacy/offline-filesecure/">
        <span class="resource-icon" aria-hidden="true"></span>
        <strong>Privacy</strong>
        <p>Clear product policies.</p>
        <em>Read policy</em>
      </a>
    </div>
  </section>
</section>

<script>
(() => {
  const carousel = document.querySelector("[data-article-carousel]");
  if (!carousel) return;

  const cards = Array.from(carousel.querySelectorAll(".article-card"));
  const prev = carousel.querySelector("[data-prev]");
  const next = carousel.querySelector("[data-next]");
  let index = 0;

  function update() {
    const card = cards[index];
    if (!card) return;
    card.scrollIntoView({ behavior: "smooth", inline: "start", block: "nearest" });
  }

  prev.addEventListener("click", () => {
    index = index <= 0 ? cards.length - 1 : index - 1;
    update();
  });

  next.addEventListener("click", () => {
    index = index >= cards.length - 1 ? 0 : index + 1;
    update();
  });
})();
</script>
