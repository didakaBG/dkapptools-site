---
import BaseLayout from "../layouts/BaseLayout.astro";

const apps = [
  {
    title: "Offline FileSecure",
    status: "Available",
    body: "Local-first Android vault for private files, offline encryption, and clear export control.",
    tags: ["Privacy", "File Tools"],
    icon: "shield",
    href: "/apps/offline-filesecure"
  },
  {
    title: "Secure Notes",
    status: "Planned",
    body: "Private encrypted notes for people who want simple offline writing without account clutter.",
    tags: ["Privacy"],
    icon: "cube",
    href: "#community"
  },
  {
    title: "Batch Image Tools",
    status: "Idea Stage",
    body: "Resize, compress, and prepare images in batches with a practical local-first workflow.",
    tags: ["Productivity"],
    icon: "bolt",
    href: "#community"
  },
  {
    title: "APK Analyzer",
    status: "Research",
    body: "Inspect Android app packages, permissions, and metadata before installing.",
    tags: ["Android Tools"],
    icon: "bot",
    href: "#community"
  },
  {
    title: "Future Experiment",
    status: "Community Vote",
    body: "A placeholder for the next useful DK App Tools project shaped by polls and feedback.",
    tags: ["Future"],
    icon: "flask",
    href: "#community"
  }
];



---
<BaseLayout
  title="DK App Tools | Practical software hub"
  description="Practical software, useful content, and community-shaped app ideas from DK App Tools."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="hero-copy">
      <p class="eyebrow">Independent software hub</p>
      <h1 id="home-title">Practical software.<br />Useful tools. <span>Built for real users.</span></h1>
      <p class="hero-lead">DK App Tools is a hub of practical apps, useful articles, and community-shaped software ideas.</p>

      <div class="hero-actions">
        <a href="/apps" class="button primary">Explore Apps <span aria-hidden="true">→</span></a>
        <a href="/articles" class="button secondary">Read Articles</a>
        <a href="#community" class="button ghost">Suggest an Idea</a>
      </div>

      <div class="hero-metrics" aria-label="DK App Tools highlights">
        <div><strong>1</strong><span>App Available</span></div>
        <div><strong>20+</strong><span>Articles & Guides</span></div>
        <div><strong>100%</strong><span>Community Driven</span></div>
      </div>
    </div>

    <div class="hero-art" aria-hidden="true">
      <div class="orbit-card orbit-card-a"><i class="ui-icon shield"></i></div>
      <div class="orbit-card orbit-card-b"><i class="ui-icon file"></i></div>
      <div class="orbit-card orbit-card-c"><i class="ui-icon users"></i></div>
      <div class="orbit-card orbit-card-d"><i class="ui-icon code"></i></div>
      <div class="orbit-shell">
        <div class="orbit-ring ring-one"></div>
        <div class="orbit-ring ring-two"></div>
        <div class="orbit-ring ring-three"></div>
        <div class="orbit-platform"></div>
        <div class="dk-cube">DK</div>
      </div>
    </div>
  </section>

  <section class="hub-overview" aria-label="DK App Tools hub areas">
    <a href="/apps" class="hub-tile apps-tile">
      <div class="tile-visual"><i class="ui-icon grid"></i></div>
      <h2>Apps</h2>
      <p>Discover practical tools built for privacy, productivity, and everyday tasks.</p>
      <span>Browse apps →</span>
    </a>

    <a href="/articles" class="hub-tile articles-tile">
      <div class="tile-visual"><i class="ui-icon doc"></i></div>
      <h2>Articles</h2>
      <p>Guides, how-tos, and insights to help you use technology with more control.</p>
      <span>Read articles →</span>
    </a>

    <a href="#community" class="hub-tile community-tile">
      <div class="tile-visual"><i class="ui-icon users"></i></div>
      <h2>Community</h2>
      <p>Share feedback, vote on ideas, and shape what gets built next.</p>
      <span>Join community →</span>
    </a>
  </section>

  <section class="page-section" id="apps-preview">
    <div class="section-heading">
      <h2>Featured Apps</h2>
      <a href="/apps">View all apps →</a>
    </div>

    <div class="app-strip">
      {apps.map((app) => (
        <a href={app.href} class:list={["app-card", app.status === "Available" ? "available" : "upcoming"]}>
          <div class="card-topline">
            <div class:list={["app-icon", app.icon]}><i class:list={["ui-icon", app.icon]}></i></div>
            <span class="status-pill">{app.status}</span>
          </div>
          <h3>{app.title}</h3>
          <p>{app.body}</p>
          <div class="tag-row">
            {app.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>
  <section class="page-section editorial-preview" id="articles-preview">
    <div class="section-heading">
      <h2>Featured Reading</h2>
      <a href="/articles">Open articles в†’</a>
    </div>

    <div class="editorial-grid">
      <a href="/articles" class="featured-article-card">
        <div class="article-thumb privacy">
          <div class="thumb-icon"><i class="ui-icon lock"></i></div>
        </div>
        <div class="article-body">
          <span>PRIVACY GUIDE</span>
          <h3>Why Offline Security Still Matters</h3>
          <p>A practical introduction to local-first thinking, private files, and why offline tools still matter.</p>
          <small>Featured guide В· 5 min read</small>
        </div>
      </a>

      <div class="article-side-list" aria-label="More articles">
        <a href="/articles">
          <span>PRODUCTIVITY</span>
          <strong>10 Small Habits That Boost Your Productivity</strong>
          <small>Practical workflow ideas</small>
        </a>
        <a href="/articles">
          <span>ANDROID</span>
          <strong>How to Analyze Android Apps Safely</strong>
          <small>Beginner-friendly safety checks</small>
        </a>
      </div>
    </div>
  </section>
  <section class="page-section community-preview" id="community">
    <div class="community-card">
      <div>
        <p class="eyebrow">Community direction</p>
        <h2>Help shape what DK App Tools builds next.</h2>
        <p>Vote on practical app ideas, suggest features, and help prioritize the roadmap without turning the homepage into a full dashboard.</p>
      </div>
      <div class="community-actions">
        <a href="/support" class="button primary">Suggest an idea в†’</a>
        <a href="/articles" class="button secondary">Read the roadmap notes</a>
      </div>
    </div>
  </section></BaseLayout>
