---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="DK App Tools | Brand Hub"
  description="Practical software. Useful tools. Built for real users."
>
  <!-- 2. Hero -->
  <section class="hero compact-hero">
    <div class="hero-grid">
      <div class="hero-content">
        <h1>Practical software. Useful tools.<br/><span class="text-gold">Built for real users.</span></h1>
        <p class="lead">
          DK App Tools is a hub of practical apps, useful articles, and community-shaped software ideas.
        </p>
        <div class="actions">
          <a href="/apps" class="button primary">Explore Apps</a>
          <a href="/articles" class="button secondary">Read Articles</a>
          <a href="/#community" class="button secondary">Suggest an Idea</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><span class="stat-num">1</span> App Available</div>
          <div class="stat"><span class="stat-num">20+</span> Articles & Guides</div>
          <div class="stat"><span class="stat-num">100%</span> Community Driven</div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="art-container">
          <div class="art-glow"></div>
          <div class="art-ring ring-1"></div>
          <div class="art-ring ring-2"></div>
          <div class="art-ring ring-3"></div>
          <div class="art-badge">DK</div>
          <div class="art-float float-1">
            <div class="css-icon-lock"></div>
          </div>
          <div class="art-float float-2">
            <div class="css-icon-file"></div>
          </div>
          <div class="art-float float-3">
            <div class="css-icon-gear"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Hub cards -->
  <section class="section hub-cards-section">
    <div class="grid-3">
      <a href="/apps" class="hub-card">
        <div class="hub-icon apps-icon">
          <div class="hub-icon-inner grid-icon"></div>
        </div>
        <h3>Apps</h3>
        <p>Browse the growing catalog of independent software products.</p>
        <span class="hub-link">Explore catalog &rarr;</span>
      </a>
      <a href="/articles" class="hub-card">
        <div class="hub-icon articles-icon">
          <div class="hub-icon-inner doc-icon"></div>
        </div>
        <h3>Articles</h3>
        <p>Read guides, privacy notes, and practical software content.</p>
        <span class="hub-link">Read latest &rarr;</span>
      </a>
      <a href="/#community" class="hub-card">
        <div class="hub-icon community-icon">
          <div class="hub-icon-inner chat-icon"></div>
        </div>
        <h3>Community</h3>
        <p>Vote on polls, provide feedback, and shape future ideas.</p>
        <span class="hub-link">Join discussion &rarr;</span>
      </a>
    </div>
  </section>

  <!-- 4. Featured Apps -->
  <section class="section">
    <div class="section-header-row">
      <div class="header-title-bar">
        <h2>Featured Apps</h2>
      </div>
      <a href="/apps" class="view-all">View all apps &rarr;</a>
    </div>
    <div class="grid-featured-apps">
      <div class="app-card available">
        <div class="app-header">
          <div class="app-icon"><div class="css-icon-shield"></div></div>
          <div class="app-status">Available</div>
        </div>
        <div class="app-body">
          <h3>Offline FileSecure</h3>
          <p>Local file protection and encryption.</p>
          <div class="app-tags">
            <span class="app-tag">Privacy</span>
            <span class="app-tag">File Tools</span>
          </div>
        </div>
      </div>
      <div class="app-card coming-soon">
        <div class="app-header">
          <div class="app-icon placeholder-icon"></div>
          <div class="app-status">Coming Soon</div>
        </div>
        <div class="app-body">
          <h3>Secure Notes</h3>
          <p>Private encrypted note taking.</p>
        </div>
      </div>
      <div class="app-card coming-soon">
        <div class="app-header">
          <div class="app-icon placeholder-icon"></div>
          <div class="app-status">Coming Soon</div>
        </div>
        <div class="app-body">
          <h3>Batch Image Tools</h3>
          <p>Local bulk image processor.</p>
        </div>
      </div>
      <div class="app-card coming-soon">
        <div class="app-header">
          <div class="app-icon placeholder-icon"></div>
          <div class="app-status">Coming Soon</div>
        </div>
        <div class="app-body">
          <h3>APK Analyzer</h3>
          <p>Deep dive into android packages.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Browse Categories -->
  <section class="section" id="categories">
    <div class="section-header-row">
      <div class="header-title-bar">
        <h2>Browse Categories</h2>
      </div>
    </div>
    <div class="grid-categories">
      <a href="#" class="category-card">
        <div class="cat-icon"><div class="css-icon-shield"></div></div>
        <div class="cat-info">
          <h4>Privacy & Security</h4>
          <p>Local-first vaults</p>
          <span class="cat-status">1 App Available</span>
        </div>
      </a>
      <a href="#" class="category-card">
        <div class="cat-icon"><div class="css-icon-file"></div></div>
        <div class="cat-info">
          <h4>File Tools</h4>
          <p>Local management</p>
          <span class="cat-status">1 App Available</span>
        </div>
      </a>
      <a href="#" class="category-card">
        <div class="cat-icon"><div class="css-icon-gear"></div></div>
        <div class="cat-info">
          <h4>Productivity</h4>
          <p>Workflow optimization</p>
          <span class="cat-status">Planned</span>
        </div>
      </a>
      <a href="#" class="category-card">
        <div class="cat-icon"><div class="thumb-art-bot small-bot"></div></div>
        <div class="cat-info">
          <h4>Android Tools</h4>
          <p>System utilities</p>
          <span class="cat-status">Planned</span>
        </div>
      </a>
      <a href="#" class="category-card">
        <div class="cat-icon cat-icon-future"></div>
        <div class="cat-info">
          <h4>Future Experiments</h4>
          <p>Community voted</p>
          <span class="cat-status">Idea Stage</span>
        </div>
      </a>
    </div>
  </section>

  <!-- 6. Latest Articles -->
  <section class="section">
    <div class="section-header-row">
      <div class="header-title-bar">
        <h2>Latest Articles</h2>
      </div>
      <a href="/articles" class="view-all">View all &rarr;</a>
    </div>
    <div class="grid-3">
      <a href="/articles" class="article-card">
        <div class="css-thumb thumb-1">
          <div class="thumb-bg-circuit"></div>
          <div class="thumb-art-lock"></div>
        </div>
        <div class="article-content">
          <h3>Why Offline Security Still Matters</h3>
          <p>Understanding the value of local-first encryption.</p>
        </div>
      </a>
      <a href="/articles" class="article-card">
        <div class="css-thumb thumb-2">
          <div class="thumb-bg-desk"></div>
          <div class="thumb-art-desk"></div>
        </div>
        <div class="article-content">
          <h3>10 Small Habits That Boost Your Productivity</h3>
          <p>Practical ways to optimize your daily software workflow.</p>
        </div>
      </a>
      <a href="/articles" class="article-card">
        <div class="css-thumb thumb-3">
          <div class="thumb-bg-bot"></div>
          <div class="thumb-art-bot"><div class="bot-eye"></div></div>
        </div>
        <div class="article-content">
          <h3>How to Analyze Android Apps Safely</h3>
          <p>A beginner's guide to inspecting APK contents.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- 7. Bottom split section -->
  <section class="section split-section" id="community">
    <div class="split-panel poll-panel">
      <div class="header-title-bar">
        <h2>What should DK App Tools build next?</h2>
      </div>
      <p class="poll-desc">Have a say in the development roadmap.</p>
      <div class="poll-items">
        <div class="poll-item">
          <div class="poll-info"><span>Secure Notes</span><span>42%</span></div>
          <div class="poll-bar-bg"><div class="poll-bar-fill" style="width: 42%"></div></div>
        </div>
        <div class="poll-item">
          <div class="poll-info"><span>Batch Image Tools</span><span>28%</span></div>
          <div class="poll-bar-bg"><div class="poll-bar-fill" style="width: 28%"></div></div>
        </div>
        <div class="poll-item">
          <div class="poll-info"><span>Password Manager</span><span>18%</span></div>
          <div class="poll-bar-bg"><div class="poll-bar-fill" style="width: 18%"></div></div>
        </div>
        <div class="poll-item">
          <div class="poll-info"><span>Other Ideas</span><span>12%</span></div>
          <div class="poll-bar-bg"><div class="poll-bar-fill" style="width: 12%"></div></div>
        </div>
      </div>
    </div>

    <div class="split-panel principles-panel">
      <div class="header-title-bar">
        <h2>Why DK App Tools</h2>
      </div>
      <div class="principles-grid">
        <div class="principle-card">
          <h4>Privacy First</h4>
          <p>Local-first processing. No hidden tracking.</p>
        </div>
        <div class="principle-card">
          <h4>Practical & Focused</h4>
          <p>Tools designed to solve specific problems.</p>
        </div>
        <div class="principle-card">
          <h4>Community Driven</h4>
          <p>Features shaped by real user feedback.</p>
        </div>
        <div class="principle-card">
          <h4>Transparent</h4>
          <p>Clear business models and honest app pages.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
