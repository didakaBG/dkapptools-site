---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Support | DK App Tools"
  description="Contact DK App Tools support."
>
  <section class="section">
    <p class="eyebrow">Support</p>
    <h1>Need help?</h1>
    <p class="lead">
      For support, privacy questions, or app-related issues, contact DK App Tools by email.
    </p>
    <div class="card">
      <h3>Email support</h3>
      <p>
        <a href="mailto:dkapps.support@proton.me">dkapps.support@proton.me</a>
      </p>
      <p>
        When contacting support, include the app name, your Android version if relevant,
        and a clear description of the issue. Do not send private vault files.
      </p>
    </div>
  </section>
</BaseLayout>
