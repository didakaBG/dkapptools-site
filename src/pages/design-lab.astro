---
// Isolated DK App Tools prototype. No layout or global CSS imports.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DK App Tools | Design Lab</title>
    <style>
      :root {
        --bg: #0b0d0e;
        --bg-2: #101214;
        --panel: rgba(20, 22, 24, 0.92);
        --panel-2: rgba(17, 19, 21, 0.94);
        --line: rgba(255, 255, 255, 0.09);
        --line-2: rgba(255, 255, 255, 0.14);
        --gold: #f0b642;
        --gold-2: #ffd36d;
        --gold-3: #a86d12;
        --green: #78c05f;
        --text: #f4f1ea;
        --muted: #c1c1bd;
        --dim: #858780;
        --soft: rgba(240, 182, 66, 0.12);
        --radius: 8px;
        --shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        min-height: 100vh;
        margin: 0;
        color: var(--muted);
        background:
          radial-gradient(circle at 68% 8%, rgba(240, 182, 66, 0.13), transparent 28rem),
          radial-gradient(circle at 13% 30%, rgba(255, 255, 255, 0.04), transparent 19rem),
          linear-gradient(180deg, #111315 0%, var(--bg) 36%, #090a0b 100%);
        font-size: 14px;
        line-height: 1.45;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px),
          radial-gradient(rgba(240, 182, 66, 0.18) 1px, transparent 1px);
        background-size: 78px 78px, 78px 78px, 22px 22px;
        mask-image: linear-gradient(to bottom, black, transparent 88%);
        opacity: 0.55;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      .page {
        width: min(1180px, calc(100% - 56px));
        margin: 0 auto;
      }

      .topbar {
        border-bottom: 1px solid var(--line);
        background: rgba(12, 14, 15, 0.86);
        backdrop-filter: blur(18px);
      }

      .header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 28px;
        min-height: 78px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 15px;
        color: var(--text);
        font-size: 21px;
        font-weight: 750;
        letter-spacing: -0.01em;
        white-space: nowrap;
      }

      .logo {
        display: grid;
        width: 40px;
        height: 40px;
        place-items: center;
        border: 1px solid var(--gold);
        border-radius: 7px;
        color: var(--gold-2);
        background:
          linear-gradient(135deg, rgba(240, 182, 66, 0.16), rgba(240, 182, 66, 0.01)),
          #101112;
        box-shadow: inset 0 0 18px rgba(240, 182, 66, 0.09), 0 0 22px rgba(240, 182, 66, 0.1);
        font-size: 20px;
        font-weight: 850;
        line-height: 1;
      }

      .nav {
        display: flex;
        justify-content: center;
        gap: 50px;
      }

      .nav a {
        color: var(--text);
        font-size: 13px;
        font-weight: 650;
      }

      .actions {
        display: flex;
        align-items: center;
        gap: 13px;
      }

      .icon-button,
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line-2);
        border-radius: 7px;
        color: var(--text);
        background: rgba(16, 17, 19, 0.82);
      }

      .icon-button {
        width: 42px;
        height: 42px;
        border-color: transparent;
      }

      .icon-button svg,
      .mini-icon svg,
      .tiny svg,
      .social svg {
        display: block;
      }

      .btn {
        min-height: 41px;
        padding: 0 23px;
        font-size: 13px;
        font-weight: 750;
      }

      .btn.gold,
      .cta.primary,
      .subscribe {
        border-color: rgba(255, 211, 109, 0.52);
        color: #171008;
        background: linear-gradient(180deg, #ffd878, #edae38);
        box-shadow: 0 0 24px rgba(240, 182, 66, 0.2);
      }

      main {
        padding: 24px 0 16px;
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(360px, 0.95fr) minmax(440px, 1.35fr);
        align-items: center;
        gap: 34px;
        min-height: 300px;
        margin-bottom: 20px;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        max-width: 610px;
        color: var(--text);
        font-size: clamp(34px, 4.2vw, 42px);
        line-height: 1.05;
        letter-spacing: -0.025em;
      }

      h1 .gold-text {
        color: var(--gold-2);
      }

      .lead {
        max-width: 520px;
        margin-top: 18px;
        color: #d4d2cc;
        font-size: 17px;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 25px;
      }

      .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 45px;
        padding: 0 22px;
        border: 1px solid var(--line-2);
        border-radius: 7px;
        color: var(--text);
        background: rgba(15, 17, 19, 0.84);
        font-weight: 760;
      }

      .metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 25px;
        margin-top: 22px;
        color: var(--text);
      }

      .metrics span {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        font-weight: 620;
      }

      .metrics span + span::before {
        content: "";
        width: 3px;
        height: 3px;
        margin-right: 5px;
        border-radius: 999px;
        background: var(--dim);
      }

      .hero-stage {
        position: relative;
        height: 310px;
        overflow: hidden;
      }

      .hero-stage::before {
        content: "";
        position: absolute;
        inset: 6px 10px 0;
        background:
          radial-gradient(ellipse at 52% 68%, rgba(240, 182, 66, 0.22), transparent 38%),
          linear-gradient(90deg, transparent, rgba(240, 182, 66, 0.14), transparent);
        filter: blur(14px);
      }

      .dk-tile {
        position: absolute;
        left: 50%;
        top: 22px;
        z-index: 3;
        display: grid;
        width: 146px;
        height: 146px;
        place-items: center;
        transform: translateX(-50%);
        border: 3px solid var(--gold-2);
        border-radius: 21px;
        color: var(--gold-2);
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.02)),
          #191b1d;
        box-shadow:
          inset 0 0 22px rgba(240, 182, 66, 0.16),
          0 0 36px rgba(240, 182, 66, 0.28),
          0 36px 55px rgba(0, 0, 0, 0.5);
        font-size: 72px;
        font-weight: 860;
        letter-spacing: -0.08em;
      }

      .platform {
        position: absolute;
        left: 50%;
        bottom: 24px;
        width: 350px;
        height: 86px;
        transform: translateX(-50%);
      }

      .platform span {
        position: absolute;
        inset: auto 0 0;
        height: 72px;
        border: 1px solid rgba(240, 182, 66, 0.35);
        border-radius: 50%;
        background:
          radial-gradient(ellipse, rgba(240, 182, 66, 0.18), transparent 55%),
          linear-gradient(180deg, rgba(255, 214, 113, 0.1), rgba(0, 0, 0, 0.12));
        box-shadow: 0 0 26px rgba(240, 182, 66, 0.18);
      }

      .platform span:nth-child(2) {
        inset: auto 42px 17px;
        height: 48px;
        border-color: rgba(255, 211, 109, 0.5);
      }

      .platform span:nth-child(3) {
        inset: auto 88px 34px;
        height: 28px;
        border-color: rgba(240, 182, 66, 0.65);
      }

      .orbit {
        position: absolute;
        left: 50%;
        top: 88px;
        z-index: 2;
        width: 380px;
        height: 86px;
        transform: translateX(-50%);
        border: 1px solid rgba(240, 182, 66, 0.3);
        border-radius: 50%;
      }

      .mini-card {
        position: absolute;
        z-index: 4;
        display: grid;
        width: 70px;
        height: 78px;
        place-items: center;
        border: 1px solid var(--line-2);
        border-radius: 8px;
        color: rgba(255, 255, 255, 0.62);
        background: rgba(19, 21, 23, 0.82);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04), var(--shadow);
      }

      .mini-card::after {
        content: "";
        position: absolute;
        top: 50%;
        width: 80px;
        height: 1px;
        background: linear-gradient(90deg, rgba(240, 182, 66, 0.65), transparent);
      }

      .mini-card.left::after {
        left: 100%;
      }

      .mini-card.right::after {
        right: 100%;
        transform: rotate(180deg);
      }

      .m-shield {
        left: 108px;
        top: 54px;
      }

      .m-users {
        left: 60px;
        top: 146px;
        width: 82px;
        height: 82px;
      }

      .m-doc {
        right: 107px;
        top: 55px;
      }

      .m-code {
        right: 62px;
        top: 146px;
        width: 82px;
        height: 82px;
      }

      .ghost-notes {
        position: absolute;
        left: 30px;
        top: 20px;
        color: rgba(240, 182, 66, 0.13);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 12px;
        line-height: 2.1;
      }

      .hub-grid,
      .article-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }

      .hub-card,
      .panel,
      .app-card,
      .cat-card,
      .article-card,
      .reason-card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.006)),
          var(--panel-2);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.025);
      }

      .hub-card {
        display: grid;
        grid-template-columns: 132px 1fr;
        min-height: 168px;
        overflow: hidden;
      }

      .hub-art {
        position: relative;
        overflow: hidden;
        background:
          radial-gradient(circle at 50% 50%, rgba(240, 182, 66, 0.18), transparent 54%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.04), transparent);
      }

      .hub-art.gray {
        background:
          radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.11), transparent 54%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.04), transparent);
      }

      .hub-art.green {
        background:
          radial-gradient(circle at 50% 50%, rgba(120, 192, 95, 0.22), transparent 54%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.035), transparent);
      }

      .cube-stack,
      .doc-stack,
      .people-stack {
        position: absolute;
        inset: 20px 15px;
      }

      .cube {
        position: absolute;
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #ffd66b, #b87918);
        clip-path: polygon(50% 0, 100% 25%, 100% 75%, 50% 100%, 0 75%, 0 25%);
        box-shadow: 0 12px 25px rgba(240, 182, 66, 0.2);
      }

      .cube:nth-child(1) {
        left: 48px;
        top: 18px;
      }

      .cube:nth-child(2) {
        left: 30px;
        top: 48px;
      }

      .cube:nth-child(3) {
        left: 66px;
        top: 48px;
      }

      .cube:nth-child(4) {
        left: 49px;
        top: 76px;
      }

      .floating {
        position: absolute;
        left: 20px;
        top: 22px;
        display: grid;
        width: 42px;
        height: 42px;
        place-items: center;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: rgba(22, 24, 26, 0.88);
        color: var(--gold-2);
      }

      .paper {
        position: absolute;
        left: 44px;
        top: 26px;
        width: 58px;
        height: 88px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 8px;
        background: linear-gradient(135deg, #404347, #17191b);
        box-shadow: 15px 12px 0 rgba(255, 255, 255, 0.04);
      }

      .paper::before,
      .paper::after {
        content: "";
        position: absolute;
        left: 14px;
        right: 14px;
        height: 1px;
        background: rgba(255, 255, 255, 0.28);
      }

      .paper::before {
        top: 32px;
      }

      .paper::after {
        top: 48px;
        right: 24px;
      }

      .person {
        position: absolute;
        width: 36px;
        height: 26px;
        border-radius: 22px 22px 6px 6px;
        background: linear-gradient(180deg, #91d576, #4c9d41);
      }

      .person::before {
        content: "";
        position: absolute;
        left: 9px;
        top: -24px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #93d76c;
      }

      .person:nth-child(1) {
        left: 27px;
        top: 82px;
      }

      .person:nth-child(2) {
        left: 66px;
        top: 80px;
        transform: scale(0.92);
      }

      .person:nth-child(3) {
        left: 49px;
        top: 55px;
        transform: scale(0.72);
        opacity: 0.8;
      }

      .hub-copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 21px 20px 18px;
      }

      h2 {
        color: var(--text);
        font-size: 21px;
        font-weight: 720;
        letter-spacing: -0.012em;
      }

      h3 {
        color: var(--text);
        font-size: 15px;
        font-weight: 740;
      }

      .hub-copy h2 {
        margin-bottom: 7px;
      }

      .hub-copy p,
      .app-card p,
      .cat-card p,
      .article-card p,
      .reason-card p,
      .footer p,
      .footer a,
      .footer li {
        color: #bbb9b2;
      }

      .link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 13px;
        color: var(--gold-2);
        font-weight: 730;
      }

      .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: 18px 0 12px;
      }

      .section-head h2 {
        position: relative;
        padding-left: 18px;
      }

      .section-head h2::before {
        content: "";
        position: absolute;
        left: 0;
        top: 4px;
        bottom: 3px;
        width: 5px;
        border-radius: 99px;
        background: linear-gradient(180deg, #ffd878, #edae38);
      }

      .section-link {
        color: var(--gold-2);
        font-size: 14px;
        font-weight: 760;
      }

      .apps-strip {
        display: grid;
        grid-template-columns: 1.25fr repeat(4, 0.88fr);
        gap: 16px;
      }

      .app-card {
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 228px;
        padding: 14px;
        overflow: hidden;
      }

      .app-card.featured {
        padding-bottom: 58px;
        background:
          radial-gradient(circle at 23% 25%, rgba(255, 255, 255, 0.1), transparent 30%),
          radial-gradient(circle at 90% 98%, rgba(240, 182, 66, 0.1), transparent 42%),
          var(--panel);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        min-height: 19px;
        padding: 0 8px;
        border: 1px solid rgba(120, 192, 95, 0.3);
        border-radius: 4px;
        color: #c3f0ad;
        background: rgba(84, 145, 64, 0.25);
        font-size: 10px;
        font-weight: 780;
      }

      .badge.soon {
        border-color: var(--line-2);
        color: #c9c7c0;
        background: rgba(255, 255, 255, 0.03);
      }

      .app-visual {
        display: grid;
        width: 76px;
        height: 76px;
        margin: 16px 0 11px;
        place-items: center;
        border: 1px solid var(--line-2);
        border-radius: 10px;
        color: var(--text);
        background:
          radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.12), transparent 70%),
          rgba(255, 255, 255, 0.025);
      }

      .placeholder .app-visual {
        margin: 40px auto 15px;
        color: #83847d;
      }

      .app-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
      }

      .version {
        padding: 2px 7px;
        border: 1px solid var(--line-2);
        border-radius: 999px;
        color: #d7d4cc;
        font-size: 10px;
      }

      .app-card p {
        margin-top: 8px;
        margin-bottom: 0;
        font-size: 12px;
        line-height: 1.42;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-top: auto;
        padding-top: 17px;
        max-width: calc(100% - 28px);
      }

      .featured .tags {
        position: absolute;
        left: 14px;
        bottom: 16px;
        margin-top: 0;
        padding-top: 0;
        max-width: calc(100% - 112px);
      }

      .tag {
        padding: 3px 6px;
        border: 1px solid var(--line-2);
        border-radius: 4px;
        color: #c6c4bd;
        background: rgba(255, 255, 255, 0.035);
        font-size: 10px;
      }

      .view-app {
        position: absolute;
        right: 16px;
        bottom: 15px;
        color: var(--gold-2);
        font-size: 13px;
        font-weight: 750;
      }

      .placeholder {
        border-style: dashed;
        border-color: rgba(255, 255, 255, 0.15);
      }

      .cats {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 18px;
      }

      .cat-card {
        display: grid;
        grid-template-columns: 42px 1fr;
        gap: 13px;
        min-height: 102px;
        padding: 17px 16px;
      }

      .cat-card p {
        margin-top: 4px;
        font-size: 12px;
      }

      .cat-card small {
        display: block;
        margin-top: 7px;
        color: #dfded8;
      }

      .mini-icon {
        color: var(--gold);
      }

      .mini-icon.green {
        color: var(--green);
      }

      .mini-icon.purple {
        color: #d2b9ff;
      }

      .mini-icon.aqua {
        color: #85dced;
      }

      .article-card {
        display: grid;
        grid-template-columns: 130px 1fr;
        min-height: 154px;
        padding: 14px;
        gap: 15px;
      }

      .thumb {
        position: relative;
        overflow: hidden;
        border-radius: 5px;
        background:
          linear-gradient(90deg, rgba(240, 182, 66, 0.17) 1px, transparent 1px),
          linear-gradient(rgba(240, 182, 66, 0.13) 1px, transparent 1px),
          radial-gradient(circle at 57% 52%, rgba(240, 182, 66, 0.42), transparent 18%),
          #151515;
        background-size: 17px 17px, 17px 17px, auto, auto;
        box-shadow: inset 0 0 40px rgba(0, 0, 0, 0.35);
      }

      .thumb.lock::after,
      .thumb.work::after,
      .thumb.android::after {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
      }

      .thumb.lock::after {
        content: "";
        width: 42px;
        height: 34px;
        margin: auto;
        border: 3px solid rgba(255, 219, 130, 0.72);
        border-radius: 6px;
        box-shadow: 0 -18px 0 -8px transparent, 0 0 24px rgba(240, 182, 66, 0.28);
      }

      .thumb.lock::before {
        content: "";
        position: absolute;
        left: 50%;
        top: 38px;
        width: 42px;
        height: 35px;
        transform: translateX(-50%);
        border: 4px solid rgba(255, 219, 130, 0.68);
        border-bottom: 0;
        border-radius: 22px 22px 0 0;
      }

      .thumb.work {
        background:
          radial-gradient(circle at 58% 28%, rgba(115, 205, 234, 0.46), transparent 14%),
          linear-gradient(135deg, rgba(40, 148, 194, 0.3), transparent 44%),
          linear-gradient(180deg, #11232a, #17130f);
      }

      .thumb.work::after {
        content: "";
        width: 72px;
        height: 42px;
        border: 2px solid rgba(110, 210, 240, 0.5);
        box-shadow: 0 43px 0 -35px rgba(240, 182, 66, 0.35);
      }

      .thumb.android {
        background:
          radial-gradient(circle at 51% 53%, rgba(130, 220, 65, 0.36), transparent 32%),
          linear-gradient(180deg, #0a120b, #161817);
      }

      .thumb.android::after {
        content: "A";
        color: #93d755;
        font-size: 70px;
        font-weight: 850;
      }

      .pill {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 3px 7px;
        border-radius: 4px;
        color: #f4f1ea;
        background: rgba(255, 255, 255, 0.1);
        font-size: 9px;
        font-weight: 820;
        text-transform: uppercase;
      }

      .pill.green {
        color: #bff3a4;
        background: rgba(120, 192, 95, 0.16);
      }

      .article-card p {
        margin-top: 8px;
        font-size: 12px;
      }

      .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-top: 16px;
        color: #c9c7c0;
        font-size: 11px;
      }

      .bottom-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 20px;
      }

      .panel {
        padding: 18px 20px;
      }

      .panel > p {
        margin-top: 3px;
        color: #c7c4be;
      }

      .poll {
        margin-top: 16px;
      }

      .poll-row {
        display: grid;
