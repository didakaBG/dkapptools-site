---
import "../styles/global.css";
const {
  title = "DK App Tools | Practical software hub",
  description = "Practical software, useful content, and community-shaped app ideas from DK App Tools."
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell">
        <a class="brand" href="/" aria-label="DK App Tools home">
          <span class="brand-badge">DK</span>
          <span class="brand-text">DK App Tools</span>
        </a>

        <nav class="nav-links" aria-label="Main navigation">
          <a href="/apps">Apps</a>
          <a href="/#categories">Categories</a>
          <a href="/articles">Articles</a>
          <a href="/#community">Community</a>
          <a href="/support">Support</a>
        </nav>

        <div class="header-actions">
          <a class="search-pill" href="/articles" aria-label="Search articles and apps">
            <span class="search-dot"></span>
            <span>Search</span>
          </a>
          <a href="/#community" class="button header-cta">Suggest idea</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-shell">
        <div class="footer-brand-block">
          <a class="brand" href="/">
            <span class="brand-badge">DK</span>
            <span class="brand-text">DK App Tools</span>
          </a>
          <p>Practical software, useful tools, and a community-shaped product roadmap.</p>
          <div class="social-row" aria-label="Social links">
            <a href="/support" aria-label="Support">?</a>
            <a href="/articles" aria-label="Articles">A</a>
            <a href="/#community" aria-label="Community">C</a>
            <a href="mailto:dkapps.support@proton.me" aria-label="Email">@</a>
          </div>
        </div>

        <div class="footer-col">
          <strong>Explore</strong>
          <a href="/apps">Apps</a>
          <a href="/#categories">Categories</a>
          <a href="/articles">Articles</a>
          <a href="/#community">Community</a>
        </div>

        <div class="footer-col">
          <strong>Support</strong>
          <a href="/support">Help center</a>
          <a href="mailto:dkapps.support@proton.me">Contact</a>
          <a href="/#community">Suggest an idea</a>
          <a href="/privacy/offline-filesecure">Privacy</a>
        </div>

        <div class="footer-col">
          <strong>Company</strong>
          <a href="/">Principles</a>
          <a href="/apps/offline-filesecure">First app</a>
          <a href="/articles">Guides</a>
          <a href="/support">Roadmap feedback</a>
        </div>

        <div class="footer-subscribe" id="subscribe">
          <strong>Stay Updated</strong>
          <p>Get updates about new apps, articles, and community polls.</p>
          <form class="subscribe-form" action="#" onsubmit="event.preventDefault()">
            <input type="email" placeholder="Enter your email" aria-label="Email address" required />
            <button type="submit" class="button primary">Subscribe</button>
          </form>
        </div>
      </div>

      <div class="footer-bottom">
        <p>В© 2026 DK App Tools. All rights reserved.</p>
        <div class="footer-legal">
          <a href="/privacy/offline-filesecure">Privacy Policy</a>
          <a href="/support">Support</a>
          <span>English</span>
        </div>
      </div>
    </footer>
  </body>
</html>
