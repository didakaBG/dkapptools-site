﻿---
import "../styles/global.css";
const {
  title = "DK App Tools | Practical software hub",
  description = "Practical software, useful content, and community-shaped app ideas from DK App Tools."
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell">
        <a class="brand" href="/" aria-label="DK App Tools home">
          <span class="brand-badge">DK</span>
          <span class="brand-text">DK App Tools</span>
        </a>

        <nav class="nav-links" aria-label="Main navigation">
          <a href="/apps">Apps</a>
          <a href="/#categories">Categories</a>
          <a href="/articles">Articles</a>
          <a href="/#community">Community</a>
          <a href="/support">Support</a>
        </nav>

        <div class="header-actions">
          <a class="search-pill" href="/articles" aria-label="Search articles and apps">
            <span class="search-dot"></span>
            <span>Search</span>
          </a>
          <a href="/#community" class="button header-cta">Suggest idea</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-compact">
        <div class="footer-brand">
          <span class="brand-badge" style="width: 28px; height: 28px; font-size: 0.7rem;">DK</span>
          <strong>DK App Tools</strong>
          <span class="separator">|</span>
          <span class="tagline">Independent software hub</span>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="/apps">Apps</a>
          <a href="/articles">Articles</a>
          <a href="/#community">Community</a>
          <a href="/support">Support</a>
          <a href="/privacy/offline-filesecure">Privacy</a>
        </nav>
        <div class="footer-legal">
          © 2026 DK App Tools.
        </div>
      </div>
    </footer>
  </body>
</html>
