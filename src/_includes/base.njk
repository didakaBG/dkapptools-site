---
siteName: DK App Tools
supportEmail: dkapps.support@proton.me
---
<!doctype html>
<html lang="{{ lang or 'en' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or site.siteName }}</title>
  <meta name="description" content="{{ description or 'DK App Tools builds practical software, privacy-conscious tools, and useful app guides.' }}">
  <meta name="theme-color" content="#090b0e">
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css?v=20260620-hero-mobile-density">
</head>
<body>
  {% set isBg = lang == 'bg' %}
  {% set homeUrl = '/bg/' if isBg else '/' %}
  {% set appsUrl = '/bg/apps/' if isBg else '/apps/' %}
  {% set articlesUrl = '/bg/articles/' if isBg else '/articles/' %}
  {% set productUrl = '/bg/apps/offline-filesecure/' if isBg else '/apps/offline-filesecure/' %}
  {% set supportUrl = '/bg/support/' if isBg else '/support/' %}
  {% set privacyUrl = '/bg/privacy/offline-filesecure/' if isBg else '/privacy/offline-filesecure/' %}
  {% set homeLabel = 'Начало' if isBg else 'Home' %}
  {% set appsLabel = 'Приложения' if isBg else 'Apps' %}
  {% set articlesLabel = 'Статии' if isBg else 'Articles' %}
  {% set supportLabel = 'Поддръжка' if isBg else 'Support' %}
  {% set privacyLabel = 'Поверителност' if isBg else 'Privacy' %}
  {% set languageBarLabel = 'Език на сайта:' if isBg else 'Website language:' %}
  {% set currentLanguageLabel = 'BG' if isBg else 'EN' %}
  {% set switcherUrl = alternateUrl or ('/' if isBg else '/bg/') %}
  {% set switcherLabel = alternateLabel or ('EN' if isBg else 'BG') %}
  {% set footerBrandCopy = 'Практични приложения, ясна продуктова информация, полезни статии и страници за поддръжка за реални продукти.' if isBg else 'Practical apps, clear product information, useful articles, and support pages for real products.' %}
  {% set learnLabel = 'Материали' if isBg else 'Learn' %}
  {% set latestArticleLabel = 'Последна статия' if isBg else 'Latest article' %}
  {% set websitePrivacyLabel = 'Поверителност на сайта' if isBg else 'Website privacy' %}
  {% set aboutLabel = 'За нас' if isBg else 'About' %}
  <header class="site-header">
    <div class="site-header-shell">
      <nav class="language-utility" aria-label="Language">
        <span class="language-utility-label">{{ languageBarLabel }}</span>
        <span class="language-current" aria-current="true">{{ currentLanguageLabel }}</span>
        <span class="language-divider" aria-hidden="true">|</span>
        <a href="{{ switcherUrl }}" hreflang="{{ 'en' if isBg else 'bg' }}">{{ switcherLabel }}</a>
      </nav>

      <nav class="site-nav navbar navbar-expand-md" aria-label="Primary navigation">
        <a class="brand-link" href="{{ homeUrl }}" aria-label="DK App Tools home">
          <span class="brand-mark">DK</span>
          <span class="brand-name">Studio</span>
        </a>

        <button class="nav-toggle navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span></span>
        </button>

        <div class="collapse navbar-collapse nav-collapse" id="mainNav">
          <ul class="nav-list">
            <li><a class="{% if activeNav == 'home' %}is-active{% endif %}" href="{{ homeUrl }}"{% if activeNav == 'home' %} aria-current="page"{% endif %}>{{ homeLabel }}</a></li>
            <li><a class="{% if activeNav == 'apps' %}is-active{% endif %}" href="{{ appsUrl }}"{% if activeNav == 'apps' %} aria-current="page"{% endif %}>{{ appsLabel }}</a></li>
            <li><a class="{% if activeNav == 'articles' %}is-active{% endif %}" href="{{ articlesUrl }}"{% if activeNav == 'articles' %} aria-current="page"{% endif %}>{{ articlesLabel }}</a></li>
            <li><a class="{% if activeNav == 'support' %}is-active{% endif %}" href="{{ supportUrl }}"{% if activeNav == 'support' %} aria-current="page"{% endif %}>{{ supportLabel }}</a></li>
            <li><a class="{% if activeNav == 'privacy' %}is-active{% endif %}" href="{{ privacyUrl }}"{% if activeNav == 'privacy' %} aria-current="page"{% endif %}>{{ privacyLabel }}</a></li>
          </ul>
        </div>
      </nav>
    </div>
  </header>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-main">
      <div class="footer-brand">
        <strong>DK App Tools</strong>
        <p>{{ footerBrandCopy }}</p>
      </div>

      <nav class="footer-group" aria-label="Apps">
        <strong>{{ appsLabel }}</strong>
        <a href="{{ appsUrl }}">{{ appsLabel }}</a>
        <a href="{{ productUrl }}">Offline FileSecure</a>
      </nav>

      <nav class="footer-group" aria-label="Learn">
        <strong>{{ learnLabel }}</strong>
        <a href="{{ articlesUrl }}">{{ articlesLabel }}</a>
        {% set latestArticle = collections.publishedArticles | first %}
        {% if latestArticle %}
          <a href="{{ latestArticle.url }}">{{ latestArticleLabel }}</a>
        {% endif %}
      </nav>

      <nav class="footer-group" aria-label="Support">
        <strong>{{ supportLabel }}</strong>
        <a href="{{ supportUrl }}">{{ supportLabel }}</a>
        <a href="{{ privacyUrl }}">{{ privacyLabel }}</a>
        <a href="/privacy/website/">{{ websitePrivacyLabel }}</a>
        <a href="/about/">{{ aboutLabel }}</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <span>© 2026 DK App Tools.</span>
      <span>Built for practical software.</span>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
