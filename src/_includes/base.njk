<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or site.siteName }}</title>
  <meta name="description" content="{{ description or 'DK App Tools builds practical privacy-first software and useful app guides.' }}">
  <meta name="theme-color" content="#08090c">
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  <header class="site-shell site-header">
    <nav class="dk-topbar" aria-label="Main navigation">
      <a class="dk-brand" href="/" aria-label="DK App Tools home">
        <span class="dk-mark">DK</span>
        <span class="dk-brand-text">DK App Tools</span>
      </a>

      <button class="navbar-toggler dk-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse dk-nav-collapse" id="mainNav">
        <ul class="dk-nav-list">
          <li><a href="/apps/">Apps</a></li>
          <li><a href="/articles/">Articles</a></li>
          <li><a href="/support/">Support</a></li>
          <li><a href="/privacy/offline-filesecure/">Privacy</a></li>
        </ul>
      </div>

      <a class="dk-user-dot" href="/support/" aria-label="Contact DK App Tools">◎</a>
    </nav>
  </header>

  {{ content | safe }}

  <footer class="site-shell dk-footer-minimal">
    <span>© 2026 DK App Tools.</span>
    <span>Tools that respect you.</span>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
