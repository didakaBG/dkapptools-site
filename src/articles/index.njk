<section class="page-shell">
  <header class="page-hero surface-panel">
    <p class="kicker">Articles</p>
    <h1>Guides and practical notes.</h1>
    <p>Short articles about privacy, local-first workflows, Android habits, and useful tools.</p>
  </header>

  <section class="compact-panel">
    <div class="article-list-grid">
      {% for post in collections.articles %}
        <a class="article-card article-list-card" href="{{ post.url }}">
          <img src="/assets/img/article-offline-first.webp" alt="" loading="lazy">
          <span class="chip">{{ post.data.category or "Article" }}</span>
          <strong>{{ post.data.title }}</strong>
          <p>{{ post.data.description }}</p>
          <em>Read article</em>
        </a>
      {% endfor %}
      <a class="article-card article-list-card" href="/articles/">
        <img src="/assets/img/article-local-vaults.webp" alt="" loading="lazy">
        <span class="chip">Privacy</span>
        <strong>How local file vaults protect privacy</strong>
        <p>Local storage keeps your files yours.</p>
        <em>Coming soon</em>
      </a>
      <a class="article-card article-list-card" href="/articles/">
        <img src="/assets/img/article-android-privacy.webp" alt="" loading="lazy">
        <span class="chip">Android</span>
        <strong>Android privacy habits that actually help</strong>
        <p>Small settings changes can make a real difference.</p>
        <em>Coming soon</em>
      </a>
    </div>
  </section>
</section>
