---
layout: base.njk
title: Articles and practical guides | DK App Tools
description: Clear explanations, product notes, and useful ideas from DK App Tools.
permalink: /articles/index.html
activeNav: articles
lang: en
alternateLabel: BG
alternateUrl: /bg/articles/
---
<section class="page-shell articles-hub">
  <header class="page-hero surface-panel articles-hero">
    <p class="kicker">Articles</p>
    <h1>Articles and practical guides</h1>
    <p>Clear explanations, product notes, and useful ideas from DK App Tools.</p>
  </header>

  {% set latest = collections.publishedArticles | first %}
  {% if latest %}
    <section class="compact-panel articles-featured-panel" aria-labelledby="latest-article-heading">
      <div class="articles-section-head">
        <p class="kicker">Latest</p>
        <h2 id="latest-article-heading">Featured article</h2>
      </div>

      <a class="featured-article-card" href="{{ latest.url }}">
        <span class="article-card-media">
          <img src="{{ latest.data.cardImage or latest.data.image or '/assets/img/article-offline-first.webp' }}" alt="{{ latest.data.cardImageAlt or '' }}" loading="eager">
        </span>
        <span class="featured-article-copy">
          <span class="article-card-meta">
            <span class="chip">{{ latest.data.category or "Article" }}</span>
          </span>
          <strong>{{ latest.data.title }}</strong>
          <span>{{ latest.data.description }}</span>
          {% if latest.data.tags %}
            <span class="article-topic-row" aria-label="Topics">
              {% for tag in latest.data.tags %}
                <small>{{ tag }}</small>
              {% endfor %}
            </span>
          {% endif %}
          <em>Read article</em>
        </span>
      </a>
    </section>
  {% endif %}
  {% if collections.publishedArticles.length > 1 %}
    <section class="compact-panel articles-list-panel" aria-labelledby="article-list-heading">
      <div class="articles-section-head">
        <p class="kicker">Recent</p>
        <h2 id="article-list-heading">More recent articles</h2>
      </div>

      <div class="article-list-grid">
        {% for post in collections.publishedArticles %}
          {% if loop.index > 1 and loop.index <= 6 %}
            <a class="article-card article-list-card" href="{{ post.url }}">
              <img src="{{ post.data.cardImage or post.data.image or '/assets/img/article-offline-first.webp' }}" alt="{{ post.data.cardImageAlt or '' }}" loading="lazy">
              <span class="article-card-meta">
                <span class="chip">{{ post.data.category or "Article" }}</span>
              </span>
              <strong>{{ post.data.title }}</strong>
              <p>{{ post.data.description }}</p>
              {% if post.data.tags %}
                <span class="article-topic-row" aria-label="Topics">
                  {% for tag in post.data.tags %}
                    <small>{{ tag }}</small>
                  {% endfor %}
                </span>
              {% endif %}
              <em>Read article</em>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if collections.publishedArticles.length > 6 %}
    <section class="compact-panel articles-list-panel" aria-labelledby="older-article-list-heading">
      <div class="articles-section-head">
        <p class="kicker">Archive</p>
        <h2 id="older-article-list-heading">Older articles</h2>
      </div>

      <div class="article-list-grid">
        {% for post in collections.publishedArticles %}
          {% if loop.index > 6 %}
            <a class="article-card article-list-card" href="{{ post.url }}">
              <img src="{{ post.data.cardImage or post.data.image or '/assets/img/article-offline-first.webp' }}" alt="{{ post.data.cardImageAlt or '' }}" loading="lazy">
              <span class="article-card-meta">
                <span class="chip">{{ post.data.category or "Article" }}</span>
              </span>
              <strong>{{ post.data.title }}</strong>
              <p>{{ post.data.description }}</p>
              {% if post.data.tags %}
                <span class="article-topic-row" aria-label="Topics">
                  {% for tag in post.data.tags %}
                    <small>{{ tag }}</small>
                  {% endfor %}
                </span>
              {% endif %}
              <em>Read article</em>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
  <section class="compact-panel articles-topics-panel" aria-labelledby="article-topics-heading">
    <div class="articles-section-head">
      <p class="kicker">Topics</p>
      <h2 id="article-topics-heading">What this section covers</h2>
    </div>
    <div class="article-topic-grid">
      <span>Offline-first design</span>
      <span>Android file safety</span>
      <span>Local encrypted vaults</span>
      <span>Privacy-conscious workflows</span>
    </div>
  </section>
</section>
