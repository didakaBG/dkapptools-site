---
permalink: "/_admin/index.html"
eleventyExcludeFromCollections: true
---
<!doctype html>
<html lang="bg">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex,nofollow">
  <title>DK App Tools Admin CMS</title>
  <style>
    :root {
      --bg: #08090a;
      --panel: rgba(24, 26, 30, 0.94);
      --panel-soft: rgba(255, 255, 255, 0.035);
      --border: rgba(255, 255, 255, 0.09);
      --border-gold: rgba(214, 168, 61, 0.26);
      --gold: #d6a83d;
      --gold-light: #f0cf77;
      --text: #f4efe6;
      --muted: #aaa59a;
      --muted-2: #7f7a70;
      --green: #7bd88f;
      --blue: #8bb9ff;
      --warn: #f0cf77;
      --danger: #ff7a7a;
      --shadow: rgba(0, 0, 0, 0.38);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(214, 168, 61, 0.13), transparent 32rem),
        radial-gradient(circle at bottom right, rgba(214, 168, 61, 0.07), transparent 32rem),
        linear-gradient(135deg, #070809, #111317 52%, #08090a);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.2;
      background-image: radial-gradient(rgba(214, 168, 61, 0.38) 1px, transparent 1px);
      background-size: 24px 24px;
      mask-image: linear-gradient(to bottom, black, transparent 86%);
    }

    button {
      font: inherit;
    }

    .shell {
      position: relative;
      z-index: 1;
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
      padding: 24px 0 44px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 14px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .mark {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border: 1px solid var(--border-gold);
      border-radius: 15px;
      color: var(--gold-light);
      background: linear-gradient(145deg, rgba(214, 168, 61, 0.18), rgba(255, 255, 255, 0.035));
      font-weight: 950;
      letter-spacing: -0.04em;
      box-shadow: 0 16px 60px rgba(214, 168, 61, 0.12);
    }

    .brand-title {
      font-size: 17px;
      font-weight: 950;
      letter-spacing: -0.03em;
    }

    .brand-subtitle {
      margin-top: 2px;
      color: var(--muted);
      font-size: 13px;
    }

    .status-pills {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 8px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      padding: 9px 12px;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.035);
      font-size: 12px;
      font-weight: 850;
      white-space: nowrap;
    }

    .pill.green {
      border-color: rgba(123, 216, 143, 0.28);
      color: var(--green);
      background: rgba(123, 216, 143, 0.08);
    }

    .pill.gold {
      border-color: var(--border-gold);
      color: var(--gold-light);
      background: rgba(214, 168, 61, 0.09);
    }

    .intro {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 14px;
      margin-bottom: 14px;
    }

    .card {
      border: 1px solid var(--border);
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(30, 33, 38, 0.94), rgba(18, 20, 23, 0.94));
      box-shadow: 0 22px 70px var(--shadow);
      overflow: hidden;
    }

    .intro-main {
      padding: 24px;
      border-color: var(--border-gold);
    }

    .kicker {
      margin-bottom: 10px;
      color: var(--gold);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(32px, 4.7vw, 54px);
      line-height: 1;
      letter-spacing: -0.055em;
    }

    .lead {
      max-width: 760px;
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.65;
    }

    .intro-side {
      padding: 22px;
    }

    .state-list {
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .state-list li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      color: var(--muted);
      font-size: 13px;
    }

    .state-list strong {
      color: var(--text);
      text-align: right;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 14px;
    }

    .summary {
      padding: 16px;
      border: 1px solid var(--border);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.032);
      min-height: 116px;
    }

    .summary-label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 850;
    }

    .summary-value {
      margin-top: 10px;
      color: var(--gold-light);
      font-size: 28px;
      font-weight: 950;
      letter-spacing: -0.05em;
    }

    .summary-note {
      margin-top: 5px;
      color: var(--muted-2);
      font-size: 12px;
      line-height: 1.35;
    }

    .layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 14px;
      align-items: start;
    }

    .rail {
      position: sticky;
      top: 16px;
      padding: 16px;
    }

    .rail-title {
      margin: 0 0 11px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .nav {
      display: grid;
      gap: 7px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 11px;
      border: 1px solid transparent;
      border-radius: 14px;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.018);
      font-size: 13px;
      font-weight: 850;
    }

    .nav-item.active {
      border-color: var(--border-gold);
      color: var(--gold-light);
      background: rgba(214, 168, 61, 0.1);
    }

    .nav-icon {
      display: grid;
      place-items: center;
      width: 24px;
      height: 24px;
      border-radius: 9px;
      background: rgba(255, 255, 255, 0.05);
      font-size: 12px;
    }

    .main {
      display: grid;
      gap: 14px;
    }

    .section {
      padding: 20px;
    }

    .section-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 16px;
    }

    .section h2 {
      margin: 0;
      font-size: 19px;
      letter-spacing: -0.035em;
    }

    .section p {
      margin: 6px 0 0;
      color: var(--muted);
      line-height: 1.55;
      font-size: 14px;
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: flex-end;
    }

    .button {
      border: 1px solid var(--border-gold);
      border-radius: 13px;
      padding: 10px 12px;
      color: var(--gold-light);
      background: rgba(214, 168, 61, 0.08);
      font-size: 12px;
      font-weight: 950;
    }

    .button.secondary {
      border-color: var(--border);
      color: var(--muted);
      background: rgba(255, 255, 255, 0.035);
    }

    .button[disabled] {
      opacity: 0.52;
      cursor: not-allowed;
      filter: grayscale(0.2);
    }

    .priority-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }

    .priority {
      padding: 16px;
      border: 1px solid var(--border);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.026);
    }

    .priority strong {
      display: block;
      margin-bottom: 6px;
      font-size: 15px;
      letter-spacing: -0.02em;
    }

    .priority span {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.48;
    }

    .split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .row-list {
      display: grid;
      gap: 9px;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 13px;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.024);
    }

    .row-title {
      color: var(--text);
      font-weight: 950;
      letter-spacing: -0.02em;
    }

    .row-meta {
      margin-top: 3px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 6px 9px;
      border-radius: 999px;
      color: var(--gold-light);
      background: rgba(214, 168, 61, 0.12);
      font-size: 11px;
      font-weight: 950;
      white-space: nowrap;
    }

    .badge.green {
      color: var(--green);
      background: rgba(123, 216, 143, 0.08);
    }

    .badge.blue {
      color: var(--blue);
      background: rgba(139, 185, 255, 0.08);
    }

    .module-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .module {
      padding: 16px;
      border: 1px solid var(--border);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.026);
      min-height: 130px;
    }

    .module-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }

    .module-icon {
      display: grid;
      place-items: center;
      width: 34px;
      height: 34px;
      border-radius: 13px;
      background: rgba(255, 255, 255, 0.05);
      color: var(--gold-light);
      font-weight: 950;
    }

    .module h3 {
      margin: 0;
      font-size: 15px;
      letter-spacing: -0.025em;
    }

    .module p {
      margin-top: 7px;
      font-size: 13px;
    }

    .health-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 9px;
    }

    .health {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: 15px;
      background: rgba(255, 255, 255, 0.024);
      color: var(--muted);
      font-size: 13px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--muted-2);
      box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.03);
      flex: 0 0 auto;
    }

    .dot.green {
      background: var(--green);
      box-shadow: 0 0 0 4px rgba(123, 216, 143, 0.09);
    }

    .dot.warn {
      background: var(--warn);
      box-shadow: 0 0 0 4px rgba(214, 168, 61, 0.09);
    }

    .footer {
      margin-top: 20px;
      color: var(--muted);
      font-size: 12px;
      text-align: center;
      line-height: 1.5;
    }

    @media (max-width: 1040px) {
      .intro,
      .layout,
      .split {
        grid-template-columns: 1fr;
      }

      .summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .rail {
        position: static;
      }

      .module-grid,
      .priority-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 680px) {
      .shell {
        width: min(100% - 22px, 1180px);
        padding-top: 16px;
      }

      .topbar,
      .section-head {
        align-items: flex-start;
        flex-direction: column;
      }

      .status-pills,
      .button-row {
        justify-content: flex-start;
      }

      .intro-main,
      .intro-side,
      .section,
      .rail {
        padding: 17px;
        border-radius: 21px;
      }

      .summary-grid,
      .module-grid,
      .priority-grid,
      .health-grid {
        grid-template-columns: 1fr;
      }

      .row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="topbar">
      <div class="brand">
        <div class="mark">DK</div>
        <div>
          <div class="brand-title">DK App Tools CMS</div>
          <div class="brand-subtitle">Защитен панел за управление на сайта</div>
        </div>
      </div>

      <div class="status-pills">
        <div class="pill green">Cloudflare Access active</div>
        <div class="pill gold">Mock mode</div>
        <div class="pill">No writes enabled</div>
      </div>
    </header>

    <section class="intro">
      <div class="card intro-main">
        <div class="kicker">Admin overview</div>
        <h1>Контролен център за DK App Tools.</h1>
        <p class="lead">
          Тази защитена CMS зона ще управлява статии, app страници, снимки, проверки и publish процес.
          В момента е mock/read-only версия: дизайнът е реалистичен, но записването и публикуването са изключени.
        </p>
      </div>

      <aside class="card intro-side">
        <div class="kicker">Системен статус</div>
        <ul class="state-list">
          <li><span>Admin host</span><strong>admin.dkapptools.com</strong></li>
          <li><span>Access layer</span><strong>Cloudflare Access</strong></li>
          <li><span>Write backend</span><strong>Not connected</strong></li>
          <li><span>Publish action</span><strong>Disabled</strong></li>
          <li><span>Browser credentials</span><strong>None</strong></li>
        </ul>
      </aside>
    </section>

    <section class="summary-grid" aria-label="CMS dashboard summary">
      <article class="summary">
        <div class="summary-label">Статии</div>
        <div class="summary-value">3</div>
        <div class="summary-note">published  draft flow planned</div>
      </article>

      <article class="summary">
        <div class="summary-label">Приложения</div>
        <div class="summary-value">1</div>
        <div class="summary-note">active page  store link later</div>
      </article>

      <article class="summary">
        <div class="summary-label">Медия</div>
        <div class="summary-value">1</div>
        <div class="summary-note">low-res warning mock</div>
      </article>

      <article class="summary">
        <div class="summary-label">Проверки</div>
        <div class="summary-value">4/5</div>
        <div class="summary-note">site health mock status</div>
      </article>

      <article class="summary">
        <div class="summary-label">Deploy</div>
        <div class="summary-value">Off</div>
        <div class="summary-note">publish disabled until backend</div>
      </article>
    </section>

    <section class="layout">
      <aside class="card rail">
        <div class="rail-title">Раздели</div>
        <nav class="nav" aria-label="CMS sections">
          <div class="nav-item active"><span class="nav-icon">1</span>Dashboard</div>
          <div class="nav-item"><span class="nav-icon">2</span>Articles</div>
          <div class="nav-item"><span class="nav-icon">3</span>Apps</div>
          <div class="nav-item"><span class="nav-icon">4</span>Media</div>
          <div class="nav-item"><span class="nav-icon">5</span>Support</div>
          <div class="nav-item"><span class="nav-icon">6</span>Privacy</div>
          <div class="nav-item"><span class="nav-icon">7</span>Health</div>
          <div class="nav-item"><span class="nav-icon">8</span>Deploy</div>
        </nav>
      </aside>

      <div class="main">
        <section class="card section">
          <div class="section-head">
            <div>
              <h2>Следващи действия</h2>
              <p>Кратък списък с най-важните стъпки преди CMS-ът да започне да записва реално.</p>
            </div>
            <div class="button-row">
              <button class="button secondary" disabled>Refresh checks</button>
              <button class="button" disabled>Open editor</button>
            </div>
          </div>

          <div class="priority-grid">
            <div class="priority">
              <strong>1. Articles editor</strong>
              <span>Structured editor с title, slug, description, card image и content blocks.</span>
            </div>
            <div class="priority">
              <strong>2. Protected preview</strong>
              <span>Preview преди publish, без статията да става публична.</span>
            </div>
            <div class="priority">
              <strong>3. Server-side publish</strong>
              <span>Backend commit към GitHub без credentials в browser-а.</span>
            </div>
          </div>
        </section>

        <section class="split">
          <div class="card section">
            <div class="section-head">
              <div>
                <h2>Съдържание</h2>
                <p>Mock overview на статии и бъдещ draft/publish статус.</p>
              </div>
              <button class="button" disabled>Нова статия</button>
            </div>

            <div class="row-list">
              <div class="row">
                <div>
                  <div class="row-title">Why offline-first security still matters</div>
                  <div class="row-meta">Published article  metadata OK</div>
                </div>
                <span class="badge green">Published</span>
              </div>

              <div class="row">
                <div>
                  <div class="row-title">How local file vaults protect privacy</div>
                  <div class="row-meta">Published article  card image OK</div>
                </div>
                <span class="badge green">Published</span>
              </div>

              <div class="row">
                <div>
                  <div class="row-title">Нова статия за бъдещ редактор</div>
                  <div class="row-meta">Draft mock  preview required  backend missing</div>
                </div>
                <span class="badge">Draft mock</span>
              </div>
            </div>
          </div>

          <div class="card section">
            <div class="section-head">
              <div>
                <h2>Publish workflow</h2>
                <p>Реалният publish процес ще мине през тези защитени стъпки.</p>
              </div>
              <span class="badge">Read-only</span>
            </div>

            <div class="row-list">
              <div class="row">
                <div>
                  <div class="row-title">Save draft</div>
                  <div class="row-meta">Writes `published: false` after backend is ready</div>
                </div>
                <span class="badge">Disabled</span>
              </div>

              <div class="row">
                <div>
                  <div class="row-title">Preview</div>
                  <div class="row-meta">Shows article/card/search preview before public release</div>
                </div>
                <span class="badge blue">Planned</span>
              </div>

              <div class="row">
                <div>
                  <div class="row-title">Publish</div>
                  <div class="row-meta">Creates GitHub commit and waits for Cloudflare deploy</div>
                </div>
                <span class="badge">Disabled</span>
              </div>
            </div>
          </div>
        </section>

        <section class="card section">
          <div class="section-head">
            <div>
              <h2>CMS модули</h2>
              <p>По-спокойна структура на основните секции, без всички детайли да се показват наведнъж.</p>
            </div>
          </div>

          <div class="module-grid">
            <article class="module">
              <div class="module-top">
                <div class="module-icon">A</div>
                <span class="badge">Mock</span>
              </div>
              <h3>Articles Studio</h3>
              <p>Статии, чернови, preview, card image, tags и publish workflow.</p>
            </article>

            <article class="module">
              <div class="module-top">
                <div class="module-icon">P</div>
                <span class="badge">Mock</span>
              </div>
              <h3>App Pages</h3>
              <p>Product страници, Google Play линкове, features, screenshots и changelog.</p>
            </article>

            <article class="module">
              <div class="module-top">
                <div class="module-icon">M</div>
                <span class="badge">Mock</span>
              </div>
              <h3>Media Library</h3>
              <p>Размери на снимки, alt text, usage tracking и low-res предупреждения.</p>
            </article>

            <article class="module">
              <div class="module-top">
                <div class="module-icon">S</div>
                <span class="badge">Mock</span>
              </div>
              <h3>Support / FAQ</h3>
              <p>Въпроси и отговори за приложения, privacy, recovery и troubleshooting.</p>
            </article>

            <article class="module">
              <div class="module-top">
                <div class="module-icon">L</div>
                <span class="badge">Mock</span>
              </div>
              <h3>Privacy / Legal</h3>
              <p>Privacy pages, last updated dates, data safety notes и policy reminders.</p>
            </article>

            <article class="module">
              <div class="module-top">
                <div class="module-icon">H</div>
                <span class="badge blue">Planned</span>
              </div>
              <h3>Site Health</h3>
              <p>Broken links, missing metadata, image quality и build-risk checks.</p>
            </article>
          </div>
        </section>

        <section class="split">
          <div class="card section">
            <div class="section-head">
              <div>
                <h2>Site health</h2>
                <p>Mock проверки, които по-късно ще пазят сайта от счупено съдържание.</p>
              </div>
              <span class="badge blue">Mock status</span>
            </div>

            <div class="health-grid">
              <div class="health"><span>Article descriptions</span><span class="dot green"></span></div>
              <div class="health"><span>Image alt text</span><span class="dot green"></span></div>
              <div class="health"><span>Low-res images</span><span class="dot warn"></span></div>
              <div class="health"><span>Internal links</span><span class="dot green"></span></div>
              <div class="health"><span>Maintenance mode</span><span class="dot green"></span></div>
              <div class="health"><span>Public admin path</span><span class="dot green"></span></div>
            </div>
          </div>

          <div class="card section">
            <div class="section-head">
              <div>
                <h2>Правила за безопасност</h2>
                <p>Докато няма backend, CMS-ът остава визуален и не записва нищо.</p>
              </div>
            </div>

            <div class="row-list">
              <div class="row">
                <div>
                  <div class="row-title">No browser credentials</div>
                  <div class="row-meta">GitHub token и private write keys не се изпращат към browser-а.</div>
                </div>
                <span class="badge green">Required</span>
              </div>

              <div class="row">
                <div>
                  <div class="row-title">Writes disabled</div>
                  <div class="row-meta">Save Draft, Publish, Upload и Maintenance writes са изключени.</div>
                </div>
                <span class="badge green">Required</span>
              </div>

              <div class="row">
                <div>
                  <div class="row-title">Preview before publish</div>
                  <div class="row-meta">Публичното съдържание се пуска само след preview и успешен deploy.</div>
                </div>
                <span class="badge blue">Planned</span>
              </div>
            </div>
          </div>
        </section>
      </div>
    </section>

    <footer class="footer">
      DK App Tools CMS  Protected mock UI  Cloudflare Access protected  No write operations enabled
